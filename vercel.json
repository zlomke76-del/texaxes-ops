{
  "version": 2,
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.ts"
    },
    {
      "src": "/(.*)",
      "dest": "server.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/admin/send-thank-you-emails",
      "schedule": "0 10 * * *"
    }
  ]
}
